# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ndhhfvddcikswvvdrofr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — get from Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Only needed for CLI migrations (npx supabase db push)
SUPABASE_DB_PASSWORD=

# Admin (single shared password)
ADMIN_PASSWORD=
# Random 32+ char string used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
